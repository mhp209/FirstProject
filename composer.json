{
    "name": "laravel/laravel",
    "type": "project",
    "description": "Laravel framework application",
    "keywords": ["laravel"],
    "license": "MIT",

    "require": {
        "php": "^8.3",
        "bacon/bacon-qr-code": "^2.0",
        "barryvdh/laravel-dompdf": "^2.0",
        "doctrine/dbal": "^3.8",
        "guzzlehttp/guzzle": "^7.8",
        "ixudra/curl": "^6.22",
        "laminas/laminas-barcode": "^2.11",
        "laravel/framework": "^10.10",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.2",
        "maatwebsite/excel": "^3.1",
        "phonepe/phonepe-pg-php-sdk": "^1.0",
        "twilio/sdk": "^8.11",
        "yajra/laravel-datatables-oracle": "^10.11"
    },

    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.9",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.0"
    },

    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helper.php"
        ]
    },

    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },

    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },

    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true,

    "repositories": [
        {
            "type": "package",
            "package": [
                {
                    "name": "phonepe/phonepe-pg-php-sdk",
                    "version": "1.0.0",
                    "dist": {
                        "type": "zip",
                        "url": "https://phonepe.mycloudrepo.io/public/repositories/phonepe-pg-php-sdk/phonepe-pg-php-sdk.zip"
                    },
                    "autoload": {
                        "classmap": ["/"]
                    }
                }
            ]
        }
    ]
}
